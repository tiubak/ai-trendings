# Environment Variables for AI Trendings Projects
# Copy this to .env for local development
# On Vercel, these are set in project settings

# Pollinations.AI (Optional - works without key)
# Get free key from: https://enter.pollinations.ai
POLLINATIONS_API_KEY=

# Hugging Face (Required for HF Inference API)
# Get token from: https://huggingface.co/settings/tokens
# Create a "Read" token with "Inference API" permissions
HUGGINGFACE_API_KEY=

# OpenRouter (Required for OpenRouter models)
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=
